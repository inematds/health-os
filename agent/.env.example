# Health OS — copy to ~/.env (your HOME dir, NOT a project .env) and fill in.
# NEVER commit your real ~/.env. Every value below is a placeholder.

# Telegram (create the bot via @BotFather)
HEALTH_BOT_TOKEN=

# Supabase (your own private project)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# AI
OPENAI_API_KEY=        # embeddings for semantic memory (text-embedding-3-small)
GOOGLE_API_KEY=        # Gemini vision (food/lab photos) + workout clips

# Dashboard
DASHBOARD_TOKEN=       # a long random string; gates the web dashboard

# WHOOP (optional wearable)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# WHOOP_REFRESH_TOKEN is written automatically by the OAuth callback, then rotated each sync.

# Optional integrations
# APIFY_TOKEN=         # for find-restaurants.sh
# <VIDEO_API_KEY>=     # for exercise_clip.py (image-to-video)
